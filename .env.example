# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Chat ID (получить у @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id_here

# Процент изменения для уведомления (по умолчанию 4)
THRESHOLD_PERCENT=4.0

# Время в минутах для отслеживания изменения (по умолчанию 5)
LOOKBACK_MINUTES=5

# Proxy settings for Russia (если сервер в РФ)
# HTTP_PROXY=socks5://91.230.238.128:443
# HTTPS_PROXY=socks5://91.230.238.128:443
# NO_PROXY=localhost,127.0.0.1
